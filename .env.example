# Infrastructure
# For docker-compose services, use container hostnames (postgres/redis), not localhost.
DATABASE_URL=postgres://synapse:synapse@postgres:5432/synapse?sslmode=disable
REDIS_URL=redis://redis:6379

# Server Config
APP_ENV=development
HTTP_PORT=8080
# Include both hostnames if you open the app as localhost or 127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# Auth (Change in production!)
JWT_SECRET=dev-secret-change-in-prod

# AI (RAG flashcard generation — optional for local dev)
# Choose providers: anthropic | gemini (generation), openai | gemini (embeddings).
# Embeddings are stored as VECTOR(1536); Gemini uses outputDimensionality=1536 to match.
# Switching embedding providers after data exists mixes vector spaces — re-embed or use a fresh DB in production.
AI_GENERATION_PROVIDER=anthropic
AI_EMBEDDING_PROVIDER=openai
ANTHROPIC_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here
GEMINI_API_KEY=your_gemini_key_here
# Optional overrides (defaults: gemini-flash-latest for generation, gemini-embedding-001 for embeddings)
# GEMINI_MODEL=gemini-flash-latest
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# LMS Service (OAuth + token encryption)
CANVAS_CLIENT_ID=your_canvas_dev_client_id
CANVAS_CLIENT_SECRET=your_canvas_dev_secret
# Generate: openssl rand -base64 32  (must decode to exactly 32 bytes)
ENCRYPTION_KEY=
FRONTEND_URL=http://localhost:4200
# OAuth callback — must match lms-service URL where Canvas redirects (local dev: port 8081).
CANVAS_REDIRECT_URI=http://localhost:8081/v1/lms/callback/canvas
# Server-side Canvas URL for lms-service (Docker: use service hostname mock-canvas).
CANVAS_INTERNAL_URL=http://mock-canvas:8082

# Mock Canvas (documentation)
MOCK_CANVAS_URL=http://mock-canvas:8082

# Optional: if the Canvas URL field uses http://mock-canvas:8082, add 127.0.0.1 mock-canvas to /etc/hosts.
# Using http://localhost:8082 does not require hosts.